{
  "name": "neutron-trader",
  "version": "2.0.0",
  "description": "A simple trading bot for Binance using Electron and React",
  "main": "./main.js",
  "scripts": {
    "react": "vite",
    "react-start": "vite",
    "electron-start": "electron .",
    "dev": "concurrently \"npm:react\" \"wait-on http://localhost:5173 && npm:electron-start\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "clean": "rimraf node_modules package-lock.json dist build",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "node-schedule": "^2.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^38.1.2",
    "electron-builder": "^26.7.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.4.0",
    "rimraf": "^6.0.1",
    "vite": "^6.3.5",
    "wait-on": "^9.0.0"
  }
}
